#!/bin/bash

module load cray-hdf5-parallel
module load cray-netcdf-hdf5parallel

BASE_DIR=$(dirname $(realpath $BASH_SOURCE))

export PATH=$BASE_DIR/XIOS3/bin:$BASE_DIR/.spack-env/view/PFUNIT-4.10/bin:$BASE_DIR/.spack-env/view/bin:$PATH
export LD_LIBRARY_PATH=$BASE_DIR/XIOS3/lib:$BASE_DIR/.spack-env/view/PFUNIT-4.10/lib:$BASE_DIR/.spack-env/view/lib:$BASE_DIR/.spack-env/view/lib64:$BASE_DIR/.spack-env/view/FARGPARSE-1.8/lib:$BASE_DIR/.spack-env/view/PFUNIT-4.10/lib:$BASE_DIR/.spack-env/view/GFTL_SHARED-1.9/lib:$LD_LIBRARY_PATH
export CPATH=$BASE_DIR/XIOS3/inc:$BASE_DIR/.spack-env/view/PFUNIT-4.10/include:$BASE_DIR/.spack-env/view/include:$CPATH

export PYTHONPATH=$BASE_DIR/.spack-env/view/lib/python:$BASE_DIR/.spack-env/view/lib64/python3.11/site-packages:$BASE_DIR/.spack-env/view/lib/python3.11/site-packages:$PYTHONPATH

export PFUNIT=$BASE_DIR/.spack-env/view/PFUNIT-4.10

export FC=ftn
export LDMPI=ftn
export FPP="cpp -P -traditional"
export FFLAGS="-I$BASE_DIR/.spack-env/view/include -I$BASE_DIR/.spack-env/view/PFUNIT-4.10/include -I$BASE_DIR/XIOS3/inc $FFLAGS"
export LDFLAGS="-L$BASE_DIR/XIOS3/lib -L$BASE_DIR/.spack-env/view/PFUNIT-4.10/lib -L$BASE_DIR/.spack-env/view/lib -L$BASE_DIR/.spack-env/view/lib64 -L$BASE_DIR/.spack-env/view/FARGPARSE-1.8/lib -L$BASE_DIR/.spack-env/view/PFUNIT-4.10/lib -L$BASE_DIR/.spack-env/view/GFTL_SHARED-1.9/lib $LDFLAGS"
